# ==============================================
# RAG System — Unified Environment Variables
# Copy this file to .env and fill in your keys.
# ==============================================

# --- Neo4j (for Graph-RAG service) ---
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# --- PostgreSQL (for Vector-RAG service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/rag_db

# --- Groq LLM (shared by all services) ---
GROQ_API_KEY=your_groq_api_key_here

# --- ElevenLabs TTS (for Voice-RAG service) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
